# ═══════════════════════════════════════════════════════════════════
# PRODUCTION Environment Configuration
# Copy this file to .env.production and fill in real values
# ═══════════════════════════════════════════════════════════════════

# ── Django Core ──────────────────────────────────────────────────
DJANGO_SECRET_KEY=CHANGE-ME-use-python-c-"from django.core.utils.crypto import get_random_string; print(get_random_string(64))"
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=social.otaskflow.com,api.social.otaskflow.com,localhost,127.0.0.1

# ── Database (PostgreSQL + PostGIS) ──────────────────────────────
DB_NAME=connector_db
DB_USER=connector_prod_user
DB_PASSWORD=CHANGE-ME-strong-database-password
DB_HOST=db
DB_PORT=5432

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT Tokens ───────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── AI / OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE-ME-your-openai-key
OPENAI_MODEL=gpt-4

# ── CORS (Flutter app origins) ───────────────────────────────────
CORS_ALLOWED_ORIGINS=https://social.otaskflow.com,https://api.social.otaskflow.com

# ── Location ─────────────────────────────────────────────────────
LOCATION_OBFUSCATION_RADIUS_METERS=200

# ── Celery ───────────────────────────────────────────────────────
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=False
